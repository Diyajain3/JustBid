datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   String     @id @default(auto()) @map("_id") @db.ObjectId
  email                String     @unique
  password             String
  role                 String     @default("user")
  name                 String?
  company              Company?
  bookmarks            Bookmark[]
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model Company {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  industry  String?
  cpvCodes  String[]
  keywords  String[]
  location  String?
  minBudget Float?
  maxBudget Float?
  matches   Match[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tender {
  id               String     @id @default(auto()) @map("_id") @db.ObjectId
  externalId       String?    @unique // Provided by Python Worker (SIMAP ID)
  publicationId    String?
  title            String
  description      String?
  cpvCodes         String[]
  deadline         DateTime?
  offerOpening     DateTime?
  location         String?
  budget           Float?
  status           String     @default("open")
  detailsFetchedAt DateTime?
  rawData          Json?
  matches          Match[]
  bookmarks        Bookmark[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Match {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId String   @db.ObjectId
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenderId  String   @db.ObjectId
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  score     Float
  reasons   String[]
  createdAt DateTime @default(now())

  @@unique([companyId, tenderId])
}

model Bookmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenderId  String   @db.ObjectId
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tenderId])
}
