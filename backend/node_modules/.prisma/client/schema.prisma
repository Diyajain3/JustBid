datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   String       @id @default(auto()) @map("_id") @db.ObjectId
  email                String       @unique
  password             String
  role                 String       @default("user")
  name                 String?
  company              Company?
  bookmarks            Bookmark[]
  bids                 Bid[]
  teams                TeamMember[]
  ownedTeams           Team[]       @relation("TeamOwner")
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

model Team {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  ownerId   String       @db.ObjectId
  owner     User         @relation("TeamOwner", fields: [ownerId], references: [id])
  members   TeamMember[]
  bids      Bid[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model TeamMember {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId    String   @db.ObjectId
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("member") // owner, admin, member
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
}

model Company {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  industry  String?
  cpvCodes  String[]
  keywords  String[]
  location  String?
  minBudget Float?
  maxBudget Float?
  matches   Match[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tender {
  id               String     @id @default(auto()) @map("_id") @db.ObjectId
  externalId       String?    @unique // Provided by Python Worker (SIMAP ID)
  publicationId    String?
  title            String
  description      String?
  cpvCodes         String[]
  deadline         DateTime?
  publicationDate  DateTime?
  offerOpening     DateTime?
  location         String?
  budget           Float?
  type             String?
  category         String?
  status           String     @default("open")
  detailsFetchedAt DateTime?
  rawData          Json?
  matches          Match[]
  bookmarks        Bookmark[]
  bids             Bid[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Match {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId String   @db.ObjectId
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenderId  String   @db.ObjectId
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  score     Float
  reasons   String[]
  createdAt DateTime @default(now())

  @@unique([companyId, tenderId])
}

model Bookmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenderId  String   @db.ObjectId
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tenderId])
}

model Bid {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenderId  String   @db.ObjectId
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  teamId    String?  @db.ObjectId
  team      Team?    @relation(fields: [teamId], references: [id])
  status    String   @default("draft") // draft, submitted, won, lost
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tenderId])
}
